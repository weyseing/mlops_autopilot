# Postgres (MLflow backend store)
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow

# MinIO (S3-compatible artifact store)
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are for MinIO, not real AWS.
# MLflow uses the S3 protocol to talk to MinIO, so it needs these.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=mlflow-artifacts
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:mlflow@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts/

# App
MODEL_NAME=mlops_autopilot_model
DRIFT_THRESHOLD=0.15

# AWS SageMaker retraining
AWS_REGION=ap-southeast-1
SAGEMAKER_ROLE_ARN=
SAGEMAKER_INSTANCE_TYPE=ml.m5.large
SAGEMAKER_USE_SPOT=true
SAGEMAKER_MAX_RUN=3600
SAGEMAKER_MAX_WAIT=7200
